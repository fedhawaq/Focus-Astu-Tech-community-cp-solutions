class Solution:
    def longestConsecutive(self, nums):
        s = set(nums)
        longest = 0

        for num in s:
            if num - 1 not in s:
                length = 1
                new= num

                while new + 1 in s:
                    new += 1
                    length += 1

                if length > longest:
                    longest = length

        return longest
